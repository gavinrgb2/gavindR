function TweenLoopRotate(p, minDur, maxDur, minDeg, maxDeg)
	if not p then return end

	minDur = minDur or 0.2
	maxDur = maxDur or 0.8
	minDeg = minDeg or 20
	maxDeg = maxDeg or 120

	p.Anchored = true

	task.spawn(function()
		while p and p.Parent do
			-- random dur & deg
			local dur = math.random() * (maxDur - minDur) + minDur
			local deg = math.random(minDeg, maxDeg)

			-- random arah
			local rx = math.rad(math.random(-deg, deg))
			local ry = math.rad(math.random(-deg, deg))
			local rz = math.rad(math.random(-deg, deg))

			local targetCF = p.CFrame * CFrame.Angles(rx, ry, rz)

			local tween = TweenService:Create(
				p,
				TweenInfo.new(
					dur,
					Enum.EasingStyle.Sine,
					Enum.EasingDirection.InOut
				),
				{CFrame = targetCF}
			)

			tween:Play()
			tween.Completed:Wait()

			-- sync
			_({
				"SyncRotate",
				{{
					Part = p,
					CFrame = p.CFrame
				}}
			})
		end
	end)
end

