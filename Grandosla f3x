local P = {}
local pending = 0

for id, def in pairs(partDefs) do
    pending += 1

    task.spawn(function()
        local ok, part = pcall(function()
            return endpoint:InvokeServer("CreatePart", def.shape, def.cframe, workspace)
        end)

        if ok and part then
            P[id] = part
        end

        pending -= 1
    end)
end

while pending > 0 do task.wait() end
finished = true

local resizeBatch={}
local colorBatch={}
local matBatch={}
local colBatch={}
local anchorBatch={}
local rotateBatch = {}
local lightData = {}
local extraData = {}
local moveBatch = {}

for id,data in pairs(partData) do
    local p = P[id]

     task.spawn(function()

             if p then
                resizeBatch[#resizeBatch+1]={Part=p,CFrame=p.CFrame,Size=data.size}
                colorBatch[#colorBatch+1]={Part=p,Color=data.color,UnionColoring=false}
                matBatch[#matBatch+1]={Part=p,Material=data.material,Transparency=data.trans}
                colBatch[#colBatch+1]={Part=p,CanCollide=data.collide}
                anchorBatch[#anchorBatch+1]={Part=p,Anchored=data.anchored}
                rotateBatch[#rotateBatch+1] = {Part = p,CFrame = partDefs[id].cframe}
                if data.name and data.name ~= "" then
                        endpoint:InvokeServer("SetName",{p},data.name)
                end
                if data.isLocked then
                        endpoint:InvokeServer("SetLocked",{p},true)
                end
            end

   end) 

end

if #rotateBatch > 0 then endpoint:InvokeServer("SyncRotate", rotateBatch) end
if #resizeBatch>0 then endpoint:InvokeServer("SyncResize",resizeBatch) end
if #colorBatch>0 then endpoint:InvokeServer("SyncColor",colorBatch) end
if #matBatch>0 then endpoint:InvokeServer("SyncMaterial",matBatch) end
if #colBatch>0 then endpoint:InvokeServer("SyncCollision",colBatch) end
if #anchorBatch>0 then endpoint:InvokeServer("SyncAnchor",anchorBatch) end

if doSyncMoveGroup == true then
if hrp then local firstPart = nil for _,p in pairs(P) do if p then firstPart = p break end end if firstPart then local pivotCF = firstPart.CFrame 
      local targetCF =
            CFrame.new(hrp.Position, hrp.Position + hrp.CFrame.LookVector)
            * CFrame.Angles(0, math.pi, 0)
            + hrp.CFrame.LookVector * 95
            + Vector3.new(0,105.1,0)

     for _,p in pairs(P) do if p then local offset = pivotCF:ToObjectSpace(p.CFrame) local newCF = targetCF * offset table.insert(moveBatch,{ Part = p,CFrame = newCF}) end end
        endpoint:InvokeServer("SyncMove", moveBatch)
    end
end
else
end

