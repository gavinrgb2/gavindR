local power = false

function togglePower()
    power = not power
    if power then
          music(7047775868, 1, 1)
        for i, part in ipairs(ringCore) do
            endpoint:InvokeServer("SyncMaterial", {
                {
                    Part = part,
                    Material = Enum.Material.Neon,
                    Transparency = part.Transparency
                }
            })
            task.wait(0.2)
            if i == #ringCore then
                music(6458308055, 1, 1)
            end
        end
    else
          music(3250635272, 1, 1)
        for _, part in ipairs(ringCore) do
            endpoint:InvokeServer("SyncMaterial", {
                {
                    Part = part,
                    Material = Enum.Material.Plastic,
                    Transparency = part.Transparency
                }
            })
            task.wait(0.2)
        end
