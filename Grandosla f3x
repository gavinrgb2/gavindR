local ringCore = {}

for _, part in pairs(P) do
    if part and part:IsA("BasePart") then
        if part.Color == Color3.fromRGB(255,0,0) then
            table.insert(ringCore, part)
        end
    end
end

table.sort(ringCore, function(a, b)
    return a.Position.Y < b.Position.Y
end)

local lowest = ringCore[1]
local highest = ringCore[#ringCore]

